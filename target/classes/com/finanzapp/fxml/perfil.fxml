<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.finanzapp.controller.PerfilController"
      styleClass="page" spacing="16">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Mi perfil" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="⚙ Ajustes" styleClass="btn-ghost" onAction="#irAjustes"/>
        <Button text="Cerrar sesión" styleClass="btn-danger" onAction="#cerrarSesion"/>
    </HBox>

    <!-- Avatar + resumen -->
    <HBox styleClass="card" spacing="24" alignment="CENTER_LEFT">
        <Label fx:id="avatarLabel" styleClass="avatar-big"/>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label fx:id="lblNombre"  style="-fx-font-size:20px;-fx-font-weight:500;"/>
            <Label fx:id="lblEmail"   styleClass="subtitle"/>
            <HBox spacing="8">
                <Label fx:id="lblSituacion" styleClass="tag-green"/>
                <Label fx:id="lblComunidad" styleClass="tag-blue"/>
            </HBox>
        </VBox>
        <HBox spacing="24">
            <VBox alignment="CENTER" spacing="2">
                <Label fx:id="statMovs"   style="-fx-font-size:22px;-fx-font-weight:500;"/>
                <Label text="movimientos" styleClass="stat-sub"/>
            </VBox>
            <VBox alignment="CENTER" spacing="2">
                <Label fx:id="statObjs"   style="-fx-font-size:22px;-fx-font-weight:500;-fx-text-fill:#185FA5;"/>
                <Label text="objetivos activos" styleClass="stat-sub"/>
            </VBox>
        </HBox>
    </HBox>

    <HBox spacing="16">

        <!-- Datos personales -->
        <VBox spacing="12" HBox.hgrow="ALWAYS">

            <VBox styleClass="card" spacing="10">
                <HBox alignment="CENTER_LEFT">
                    <Label text="DATOS PERSONALES" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnEditToggle" text="✏ Editar" styleClass="btn-ghost"
                            style="-fx-font-size:12px;" onAction="#toggleEditar"/>
                </HBox>

                <!-- Vista -->
                <VBox fx:id="vistaPanel" spacing="0">
                    <HBox styleClass="data-row"><Label text="Nombre" styleClass="data-key"/><Label fx:id="vNombre"   styleClass="data-val"/></HBox>
                    <HBox styleClass="data-row"><Label text="Email"  styleClass="data-key"/><Label fx:id="vEmail"    styleClass="data-val"/></HBox>
                    <HBox styleClass="data-row"><Label text="Teléfono" styleClass="data-key"/><Label fx:id="vTelefono" styleClass="data-val"/></HBox>
                    <HBox styleClass="data-row"><Label text="Fecha de nacimiento" styleClass="data-key"/><Label fx:id="vFechaNac" styleClass="data-val"/></HBox>
                    <HBox styleClass="data-row" style="-fx-border-width:0;"><Label text="Comunidad" styleClass="data-key"/><Label fx:id="vComunidad" styleClass="data-val"/></HBox>
                </VBox>

                <!-- Edición -->
                <VBox fx:id="editPanel" spacing="8" visible="false" managed="false">
                    <Label text="Nombre completo" styleClass="form-label"/>
                    <TextField fx:id="eNombre"   styleClass="form-input"/>
                    <Label text="Email"           styleClass="form-label"/>
                    <TextField fx:id="eEmail"     styleClass="form-input"/>
                    <Label text="Teléfono"        styleClass="form-label"/>
                    <TextField fx:id="eTelefono"  styleClass="form-input"/>
                    <Label text="Fecha de nacimiento" styleClass="form-label"/>
                    <DatePicker fx:id="eFechaNac" maxWidth="Infinity" styleClass="form-input"/>
                    <Label text="Comunidad Autónoma" styleClass="form-label"/>
                    <ComboBox fx:id="eComunidad"  maxWidth="Infinity" styleClass="form-input"/>
                    <Label fx:id="lblPerfilMsg"  styleClass="info-label"  wrapText="true"/>
                    <Label fx:id="lblPerfilErr"  styleClass="error-label" wrapText="true"/>
                    <HBox spacing="8">
                        <Button text="Guardar cambios" styleClass="btn-primary" onAction="#guardarPerfil"/>
                        <Button text="Cancelar"        styleClass="btn-ghost"   onAction="#toggleEditar"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Seguridad -->
            <VBox styleClass="card" spacing="10">
                <Label text="SEGURIDAD DE LA CUENTA" styleClass="card-title"/>
                <Label text="Contraseña actual" styleClass="form-label"/>
                <PasswordField fx:id="passActual"   promptText="••••••••"            styleClass="form-input"/>
                <Label text="Nueva contraseña"  styleClass="form-label"/>
                <PasswordField fx:id="passNueva"    promptText="Mínimo 8 caracteres" styleClass="form-input"/>
                <Label text="Confirmar contraseña" styleClass="form-label"/>
                <PasswordField fx:id="passConfirm"  promptText="Repite la contraseña" styleClass="form-input"/>
                <Label fx:id="lblPassMsg" styleClass="info-label"  wrapText="true"/>
                <Label fx:id="lblPassErr" styleClass="error-label" wrapText="true"/>
                <Button text="Cambiar contraseña" styleClass="btn-primary" onAction="#cambiarPassword"/>
            </VBox>
        </VBox>

        <!-- Situación financiera -->
        <VBox spacing="12" HBox.hgrow="ALWAYS">
            <VBox styleClass="card" spacing="10">
                <Label text="SITUACIÓN FINANCIERA" styleClass="card-title"/>

                <Label text="Situación laboral" styleClass="form-label"/>
                <ComboBox fx:id="cmbSituacion" maxWidth="Infinity" styleClass="form-input"/>

                <Label text="Ingresos netos mensuales (€)" styleClass="form-label"/>
                <TextField fx:id="txtIngresos" styleClass="form-input"/>
                <Label text="Usado en el simulador de préstamos y en los consejos personalizados."
                       styleClass="hint-label" wrapText="true"/>

                <Label text="Objetivo financiero principal" styleClass="form-label"/>
                <ComboBox fx:id="cmbObjetivo" maxWidth="Infinity" styleClass="form-input"/>

                <Label text="Presupuesto mensual máximo de gastos (€)" styleClass="form-label"/>
                <TextField fx:id="txtPresupuesto" styleClass="form-input"/>
                <Label text="Recibirás una alerta cuando te acerques al límite."
                       styleClass="hint-label" wrapText="true"/>

                <Label fx:id="lblFinMsg" styleClass="info-label" wrapText="true"/>
                <Button text="Guardar situación financiera" styleClass="btn-primary"
                        maxWidth="Infinity" onAction="#guardarFinanciera"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>
