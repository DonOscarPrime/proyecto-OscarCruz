<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.finanzapp.controller.NotificacionesController"
      styleClass="page" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Notificaciones" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="Marcar todas como leídas" styleClass="btn-ghost" onAction="#marcarLeidas"/>
    </HBox>

    <VBox styleClass="card" spacing="0" fx:id="notifList"/>

</VBox>
