<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.finanzapp.controller.GastosController"
      styleClass="page" spacing="16">

    <Label text="Ingresos y gastos" styleClass="page-title"/>

    <HBox spacing="12">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Ingresos totales"       styleClass="stat-label"/>
            <Label fx:id="estadisticaIngreso"    styleClass="stat-value stat-up"/>
            <Label text="todos los movimientos"  styleClass="stat-sub"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Gastos totales"         styleClass="stat-label"/>
            <Label fx:id="estadisticaGastos"     styleClass="stat-value stat-down"/>
            <Label text="todos los movimientos"  styleClass="stat-sub"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Balance actual"         styleClass="stat-label"/>
            <Label fx:id="estadisticaBalance"    styleClass="stat-value"/>
            <Label fx:id="subBalance"            styleClass="stat-sub"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Tasa de ahorro"         styleClass="stat-label"/>
            <Label fx:id="estadisticaTasa"       styleClass="stat-value"/>
            <Label text="de ingresos ahorrado"   styleClass="stat-sub"/>
        </VBox>
    </HBox>

    <HBox spacing="12" VBox.vgrow="ALWAYS">

        <VBox styleClass="card" spacing="10" prefWidth="340" minWidth="300">
            <Label text="NUEVO MOVIMIENTO" styleClass="card-title"/>

            <Label text="Tipo" styleClass="form-label"/>
            <ComboBox fx:id="cmbTipo" maxWidth="Infinity" styleClass="form-input"/>

            <Label text="Cantidad (€)" styleClass="form-label"/>
            <TextField fx:id="txtCantidad" promptText="0,00" styleClass="form-input"/>

            <Label text="Categoría" styleClass="form-label"/>
            <ComboBox fx:id="cmbCategoria" maxWidth="Infinity" styleClass="form-input"/>

            <Label text="Descripción" styleClass="form-label"/>
            <TextField fx:id="txtNombre" promptText="Ej. Cena con amigos" styleClass="form-input"/>

            <Label text="Notas (opcional)" styleClass="form-label"/>
            <TextField fx:id="txtNotas" promptText="Opcional" styleClass="form-input"/>

            <Label text="Fecha" styleClass="form-label"/>
            <DatePicker fx:id="dateFecha" maxWidth="Infinity" styleClass="form-input"/>

            <Label fx:id="lblMsg" wrapText="true" styleClass="info-label"/>
            <Label fx:id="TextoError" wrapText="true" styleClass="error-label"/>

            <Button text="Guardar movimiento" styleClass="btn-primary"
                    maxWidth="Infinity" onAction="#guardar"/>
        </VBox>

        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:0 0 12 0;">
                <Label text="MOVIMIENTOS" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cmbFiltroTipo" styleClass="form-input" prefWidth="120"/>
                <TextField fx:id="TextoMensage" promptText="Buscar..." styleClass="form-input" prefWidth="140"/>
            </HBox>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane" prefHeight="450">
                <VBox fx:id="txList" spacing="0"/>
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>
