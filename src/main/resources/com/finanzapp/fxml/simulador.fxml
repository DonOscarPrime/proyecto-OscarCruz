<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.finanzapp.controller.SimuladorController"
      styleClass="page" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Simulador de hábitos" styleClass="page-title"/>
            <Label text="Haz clic en una tarjeta para ajustar la frecuencia. Ve el impacto en tu bolsillo al momento."
                   styleClass="subtitle" wrapText="true"/>
        </VBox>
        <Button text="+ Añadir hábito" styleClass="btn-ghost" onAction="#toggleForm"/>
    </HBox>

    <HBox styleClass="card-accent" spacing="24" alignment="CENTER_LEFT">
        <VBox spacing="3">
            <Label text="Gasto actual en hábitos" styleClass="accent-label"/>
            <Label fx:id="lblActual" styleClass="accent-value"/>
        </VBox>
        <Label text="→" style="-fx-font-size:18px;-fx-text-fill:#1D9E75;-fx-opacity:0.5;"/>
        <VBox spacing="3">
            <Label text="Si alcanzas tus objetivos" styleClass="accent-label"/>
            <Label fx:id="txtObj" styleClass="accent-value"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox spacing="3" alignment="CENTER_RIGHT">
            <Label text="Ahorro mensual posible" styleClass="accent-label"/>
            <Label fx:id="lblMes" styleClass="accent-value-big"/>
        </VBox>
        <VBox spacing="3" alignment="CENTER_RIGHT">
            <Label text="Ahorro anual posible" styleClass="accent-label"/>
            <Label fx:id="lblAnio" styleClass="accent-value-big"/>
        </VBox>
    </HBox>

    <VBox fx:id="formPanel" styleClass="card" spacing="10" visible="false" managed="false">
        <Label text="NUEVO HÁBITO" styleClass="card-title"/>
        <HBox spacing="10">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Emoji" styleClass="form-label"/>
                <TextField fx:id="Emoji" promptText="☕" prefWidth="60" styleClass="form-input"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Nombre del hábito" styleClass="form-label"/>
                <TextField fx:id="Nombre" promptText="Ej. Café fuera de casa" styleClass="form-input"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Coste (€)" styleClass="form-label"/>
                <TextField fx:id="Coste" promptText="2.50" styleClass="form-input"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Frecuencia actual" styleClass="form-label"/>
                <TextField fx:id="FrecuenciaAhora" promptText="5" styleClass="form-input"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Objetivo" styleClass="form-label"/>
                <TextField fx:id="frecuenciaObjetivo" promptText="2" styleClass="form-input"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Unidad" styleClass="form-label"/>
                <ComboBox fx:id="selectUnidad" styleClass="form-input"/>
            </VBox>
        </HBox>
        <HBox spacing="8">
            <Button text="Añadir hábito" styleClass="btn-primary" onAction="#guardarHabito"/>
            <Button text="Cancelar"      styleClass="btn-ghost"   onAction="#toggleForm"/>
        </HBox>
    </VBox>


    <FlowPane fx:id="habitosGrid" hgap="12" vgap="12"/>


    <HBox styleClass="tip-card" spacing="12" alignment="CENTER_LEFT">
        <Label text="💡" style="-fx-font-size:18px;"/>
        <Label fx:id="Tip" wrapText="true" HBox.hgrow="ALWAYS" styleClass="tip-text"
               text="Ajusta las frecuencias de tus hábitos para ver cómo cambia tu ahorro mensual."/>
    </HBox>
</VBox>
