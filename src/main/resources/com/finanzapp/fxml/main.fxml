<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.finanzapp.controller.MainController"
            fx:id="panelRoot"
            styleClass="root-pane" prefWidth="1200" prefHeight="750">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="6">
            <HBox alignment="CENTER_LEFT" spacing="7">
                <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                    <image><Image url="@/com/finanzapp/images/logo.png"/></image>
                </ImageView>
                <Label text="Fox Wallet" styleClass="logo"/>
            </HBox>
            <HBox spacing="4" HBox.hgrow="ALWAYS">
                <Button fx:id="navegaDashboard"      text="Dashboard"      styleClass="nav-tab,nav-tab-active" onAction="#mostrarDashboard"/>
                <Button fx:id="navegaGastos"         text="Ingresos/Gastos" styleClass="nav-tab"              onAction="#mostrarGasto"/>
                <Button fx:id="navegaSimulador"      text="Simulador"      styleClass="nav-tab"               onAction="#mostrarSimulador"/>
<Button fx:id="navegaObjetivos"      text="Objetivos"      styleClass="nav-tab"               onAction="#mostrarObjetivos"/>
                <Button fx:id="navegaHistorial"      text="Historial"      styleClass="nav-tab"               onAction="#mostrarHistorial"/>
                <Button fx:id="navegaRenta"          text="Renta"          styleClass="nav-tab"               onAction="#mostrarRenta"/>
            </HBox>

            <Button fx:id="notBtn" text="🔔" styleClass="nav-tab" onAction="#mostrarNotificaciones"/>
            <!-- Toggle modo oscuro -->
            <Button fx:id="temaBtn" text="🌙" styleClass="theme-toggle-btn" onAction="#toggleModoOscuro">
                <tooltip><Tooltip text="Cambiar tema"/></tooltip>
            </Button>
            <Button fx:id="avatarBtn" styleClass="avatar-btn" onAction="#mostrarPerfil"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" fx:id="scrollPane">
            <StackPane fx:id="areaDeContenido" styleClass="content-area"/>
        </ScrollPane>
    </center>

</BorderPane>
