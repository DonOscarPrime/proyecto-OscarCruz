<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.finanzapp.controller.LoginController"
           styleClass="root-pane">

    <VBox alignment="CENTER" spacing="0" maxWidth="420" styleClass="login-card">

        <!-- Logo -->
        <VBox alignment="CENTER" spacing="6" styleClass="login-logo-wrap">
            <HBox alignment="CENTER" spacing="10">
                <ImageView fitWidth="44" fitHeight="44" preserveRatio="true">
                    <image><Image url="@/com/finanzapp/images/logo.png"/></image>
                </ImageView>
                <Label text="Fox Wallet" styleClass="login-logo"/>
            </HBox>
            <Label text="Controla tu dinero. Construye tu futuro." styleClass="login-subtitle"/>
        </VBox>

        <!-- Tabs login / registro -->
        <HBox styleClass="login-tabs" spacing="0">
            <Button fx:id="tabLoginBtn" text="Iniciar sesión" styleClass="login-tab,login-tab-active"
                    onAction="#showLogin" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Button fx:id="tabRegBtn" text="Crear cuenta" styleClass="login-tab"
                    onAction="#showRegister" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Panel LOGIN -->
        <VBox fx:id="loginPanel" spacing="14" styleClass="login-form">
            <Label text="Email" styleClass="form-label"/>
            <TextField fx:id="loginEmail" promptText="tu@email.com" styleClass="form-input"/>
            <Label text="Contraseña" styleClass="form-label"/>
            <PasswordField fx:id="loginPass" promptText="••••••••" styleClass="form-input"/>
            <Label fx:id="loginError" styleClass="error-label" wrapText="true"/>
            <Button text="Entrar" styleClass="btn-primary" maxWidth="Infinity"
                    onAction="#doLogin"/>
            <Label text="Demo: oscar@email.com / Demo1234!" styleClass="hint-label" alignment="CENTER"/>
        </VBox>

        <!-- Panel REGISTRO -->
        <VBox fx:id="registerPanel" spacing="14" styleClass="login-form" visible="false" managed="false">
            <Label text="Nombre completo" styleClass="form-label"/>
            <TextField fx:id="regNombre" promptText="Ej. Ana García" styleClass="form-input"/>
            <Label text="Email" styleClass="form-label"/>
            <TextField fx:id="regEmail" promptText="tu@email.com" styleClass="form-input"/>
            <Label text="Contraseña" styleClass="form-label"/>
            <PasswordField fx:id="regPass" promptText="Mínimo 8 caracteres" styleClass="form-input"/>
            <Label text="Confirmar contraseña" styleClass="form-label"/>
            <PasswordField fx:id="regPass2" promptText="Repite la contraseña" styleClass="form-input"/>
            <Label fx:id="regError" styleClass="error-label" wrapText="true"/>
            <Button text="Crear cuenta" styleClass="btn-primary" maxWidth="Infinity"
                    onAction="#doRegister"/>
        </VBox>

    </VBox>
</StackPane>
