<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.finanzapp.controller.RentaController"
      styleClass="page" spacing="16">

    <Label text="Estimación del IRPF" styleClass="page-title"/>
    <Label text="Calculadora orientativa. No sustituye a la declaración oficial de la AEAT."
           styleClass="subtitle" wrapText="true"/>

    <HBox spacing="12">

        <!-- ── Formulario ── -->
        <VBox styleClass="card" spacing="10" prefWidth="340" maxWidth="340">

            <Label text="Salario bruto anual (€)" styleClass="form-label"/>
            <TextField fx:id="salariotxt" promptText="25000" styleClass="form-input"/>

            <Label text="Retenciones ya practicadas (€)" styleClass="form-label"/>
            <TextField fx:id="retencionestxt" promptText="0" styleClass="form-input"/>

            <Label text="Hijos a cargo" styleClass="form-label"/>
            <Label text="-600 € de deducción por hijo (orientativo)"
                   style="-fx-font-size:11px;-fx-text-fill:-color-text3;"/>
            <Spinner fx:id="contadorHijos" min="0" max="10" initialValue="0"
                     editable="true" maxWidth="Infinity"/>

            <Label fx:id="lblErrorRenta" styleClass="error-label" wrapText="true"/>
            <Button text="Calcular" styleClass="btn-primary"
                    maxWidth="Infinity" onAction="#calcular"/>
        </VBox>

        <!-- ── Resultados ── -->
        <VBox spacing="12" HBox.hgrow="ALWAYS">

            <VBox fx:id="resultPanel" styleClass="card" spacing="10"
                  visible="false" managed="false">

                <Label text="RESULTADO ESTIMADO" styleClass="card-title"/>

                <HBox spacing="12">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label text="Base imponible" styleClass="stat-label"/>
                        <Label fx:id="lblBase" styleClass="stat-value"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label text="Cuota estimada" styleClass="stat-label"/>
                        <Label fx:id="lblCuota" styleClass="stat-value stat-down"/>
                    </VBox>
                </HBox>

                <HBox spacing="12">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label text="Tipo efectivo" styleClass="stat-label"/>
                        <Label fx:id="lblTipoEfectivo" styleClass="stat-value"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label text="Retenciones" styleClass="stat-label"/>
                        <Label fx:id="lblRetenciones" styleClass="stat-value stat-up"/>
                    </VBox>
                </HBox>

                <VBox styleClass="stat-card" alignment="CENTER" spacing="2">
                    <Label text="Resultado (a pagar / a devolver)" styleClass="stat-label"/>
                    <Label fx:id="lblResultado" styleClass="stat-value"
                           style="-fx-font-size:26px;"/>
                </VBox>

                <Label text="TRAMOS APLICADOS" styleClass="card-title"/>
                <VBox fx:id="tramosBox" spacing="4"/>

                <Separator/>

                <Button text="Exportar informe PDF" styleClass="btn-primary"
                        maxWidth="Infinity" onAction="#exportarPDF"/>
                <Label fx:id="lblPdfStatus" text="" styleClass="info-label" wrapText="true"/>
            </VBox>

            <VBox styleClass="tip-card" spacing="8">
                <Label text="⚠ Aviso legal"
                       style="-fx-font-weight:600;-fx-text-fill:#BA7517;-fx-font-size:13px;"/>
                <Label text="Esta herramienta es solo orientativa. No tiene en cuenta deducciones autonómicas, circunstancias personales ni cambios normativos. Consulta a un asesor fiscal o usa el programa oficial de la AEAT para tu declaración definitiva."
                       wrapText="true" styleClass="tip-text"/>
            </VBox>
        </VBox>

    </HBox>
</VBox>
