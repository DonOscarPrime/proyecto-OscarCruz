<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.finanzapp.controller.PrestamosController"
      styleClass="page" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Simulador de préstamos" styleClass="page-title"/>
            <Label text="Introduce los datos manualmente para un cálculo preciso." styleClass="subtitle"/>
        </VBox>
    </HBox>

    <HBox spacing="12" VBox.vgrow="ALWAYS">

        <!-- ── Panel izquierdo: inputs ── -->
        <VBox spacing="12" prefWidth="340" minWidth="280">

            <!-- Tipo -->
            <VBox styleClass="card" spacing="10">
                <Label text="TIPO DE PRÉSTAMO" styleClass="card-title"/>
                <FlowPane hgap="8" vgap="8">
                    <Button fx:id="btnPersonal"  text="Personal"  styleClass="loan-type-btn,loan-type-active" onAction="#setTipo"/>
                    <Button fx:id="btnHipoteca"  text="Hipoteca"  styleClass="loan-type-btn"                  onAction="#setTipo"/>
                    <Button fx:id="btnCoche"     text="Coche"     styleClass="loan-type-btn"                  onAction="#setTipo"/>
                    <Button fx:id="btnEstudios"  text="Estudios"  styleClass="loan-type-btn"                  onAction="#setTipo"/>
                </FlowPane>
                <Label text="O escribe un tipo personalizado:" styleClass="hint-label"/>
                <TextField fx:id="txtTipoPersonalizado"
                           promptText="Ej: Reforma, Negocio, Viaje…"
                           styleClass="form-input"
                           onAction="#setTipoPersonalizado"/>
                <Label fx:id="lblTipoActivo"
                       text="Tipo seleccionado: Personal"
                       styleClass="hint-label"
                       style="-fx-font-weight:600;"/>
            </VBox>

            <!-- Datos -->
            <VBox styleClass="card" spacing="8">
                <Label text="DATOS DEL PRÉSTAMO" styleClass="card-title"/>

                <Label text="Capital solicitado (€)" styleClass="form-label"/>
                <TextField fx:id="txtCapital" text="10000" promptText="Ej: 150000" styleClass="form-input"/>
                <Label text="Introduce el importe en euros sin puntos ni comas" styleClass="hint-label"/>

                <Label text="Plazo (meses)" styleClass="form-label"/>
                <TextField fx:id="txtPlazo" text="36" promptText="Ej: 60" styleClass="form-input"/>
                <Label text="Personal: 6-120 · Hipoteca: hasta 360 · Coche: hasta 96" styleClass="hint-label"/>

                <Label text="TIN anual (%)" styleClass="form-label"/>
                <TextField fx:id="txtTin" text="6.5" promptText="Ej: 3.5" styleClass="form-input"/>
                <Label text="Tasa de Interés Nominal anual. Acepta decimales (ej: 3.75)" styleClass="hint-label"/>

                <Label text="Comisión de apertura (%)" styleClass="form-label"/>
                <TextField fx:id="txtComision" text="1.0" promptText="Ej: 1.0" styleClass="form-input"/>

                <Label text="Seguro vinculado (€/mes)" styleClass="form-label"/>
                <TextField fx:id="txtSeguro" text="0" promptText="Ej: 15" styleClass="form-input"/>

                <Label fx:id="lblError" styleClass="error-label" text="" wrapText="true"/>
            </VBox>

            <!-- Botón guardar -->
            <VBox styleClass="card" spacing="8">
                <Label text="GUARDAR SIMULACIÓN" styleClass="card-title"/>
                <Label text="Guarda esta simulación en tu historial para consultarla más adelante." styleClass="hint-label" wrapText="true"/>
                <Button text="💾  Guardar simulación" styleClass="btn-primary"
                        onAction="#guardarSimulacion" maxWidth="Infinity"/>
                <Label fx:id="lblGuardado" text="" styleClass="info-label"/>
            </VBox>

        </VBox>

        <!-- ── Panel derecho: resultados ── -->
        <VBox spacing="12" HBox.hgrow="ALWAYS">

            <!-- Cuota principal -->
            <VBox styleClass="card-blue" spacing="6" alignment="CENTER">
                <Label text="Pagarías cada mes" styleClass="blue-label"/>
                <Label fx:id="lblCuota" styleClass="cuota-value" text="—"/>
                <Label fx:id="lblCuotaSub" styleClass="blue-label" text=" "/>
            </VBox>

            <!-- Stats -->
            <HBox spacing="12">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <Label text="Total a devolver"    styleClass="stat-label"/>
                    <Label fx:id="lblTotal"           styleClass="stat-value" text="—"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <Label text="Intereses totales"   styleClass="stat-label"/>
                    <Label fx:id="lblIntereses"       styleClass="stat-value stat-down" text="—"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <Label text="Coste por 100€"      styleClass="stat-label"/>
                    <Label fx:id="lblCostePor100"     styleClass="stat-value stat-amber" text="—"/>
                </VBox>
            </HBox>

            <!-- Barra capital vs intereses -->
            <VBox styleClass="card" spacing="10">
                <Label text="¿CÓMO SE REPARTE LO QUE PAGAS?" styleClass="card-title"/>
                <HBox fx:id="barraDistrib" prefHeight="20"
                      style="-fx-background-radius:6;-fx-background-color:#F0EEE9;"/>
                <HBox spacing="16">
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="■" style="-fx-text-fill:#185FA5;-fx-font-size:10px;"/>
                        <Label text="Capital"   styleClass="stat-sub"/>
                        <Label fx:id="lblPctCap" styleClass="stat-sub" style="-fx-font-weight:bold;"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="■" style="-fx-text-fill:#D85A30;-fx-font-size:10px;"/>
                        <Label text="Intereses" styleClass="stat-sub"/>
                        <Label fx:id="lblPctInt" styleClass="stat-sub" style="-fx-font-weight:bold;"/>
                    </HBox>
                </HBox>
            </VBox>

            <!-- Tabla amortización -->
            <VBox styleClass="card" spacing="8">
                <Label text="TABLA DE AMORTIZACIÓN (primeros 24 meses)" styleClass="card-title"/>
                <ScrollPane fitToWidth="true" prefHeight="200" styleClass="scroll-pane">
                    <TableView fx:id="tablaAmort" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colMes"   text="Mes"     prefWidth="55"/>
                            <TableColumn fx:id="colCuota" text="Cuota"   prefWidth="90"/>
                            <TableColumn fx:id="colCap"   text="Capital" prefWidth="90"/>
                            <TableColumn fx:id="colInt"   text="Interés" prefWidth="90"/>
                            <TableColumn fx:id="colSaldo" text="Saldo"   prefWidth="110"/>
                        </columns>
                    </TableView>
                </ScrollPane>
            </VBox>

            <!-- Historial guardado -->
            <VBox styleClass="card" spacing="8">
                <Label text="SIMULACIONES GUARDADAS" styleClass="card-title"/>
                <TableView fx:id="tablaHistorial" styleClass="table-view" prefHeight="140">
                    <columns>
                        <TableColumn fx:id="hColTipo"    text="Tipo"      prefWidth="90"/>
                        <TableColumn fx:id="hColCapital" text="Capital"   prefWidth="100"/>
                        <TableColumn fx:id="hColPlazo"   text="Plazo"     prefWidth="80"/>
                        <TableColumn fx:id="hColTin"     text="TIN"       prefWidth="60"/>
                        <TableColumn fx:id="hColCuota"   text="Cuota/mes" prefWidth="100"/>
                    </columns>
                    <placeholder><Label text="Aún no has guardado ninguna simulación" styleClass="subtitle"/></placeholder>
                </TableView>
            </VBox>

            <!-- Consejo -->
            <HBox styleClass="tip-card" spacing="12" alignment="CENTER_LEFT">
                <Label text="💡" style="-fx-font-size:18px;"/>
                <Label fx:id="lblConsejo" wrapText="true" HBox.hgrow="ALWAYS" styleClass="tip-text"
                       text="Introduce los datos del préstamo para ver el análisis."/>
            </HBox>

        </VBox>
    </HBox>
</VBox>
