<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.finanzapp.controller.HistorialController"
      styleClass="page" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Historial de movimientos" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="seleccionarMes"  prefWidth="130" styleClass="form-input"/>
        <ComboBox fx:id="seleccionarAnio" prefWidth="90"  styleClass="form-input"/>
        <ComboBox fx:id="seleccionarTipo" prefWidth="110" styleClass="form-input"/>
        <TextField fx:id="textBusc" promptText="🔍 Buscar..." styleClass="form-input" prefWidth="150"/>
    </HBox>

    <HBox spacing="12">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Ingresos"          styleClass="stat-label"/>
            <Label fx:id="estadisticaIng"   styleClass="stat-value stat-up"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Gastos"            styleClass="stat-label"/>
            <Label fx:id="estadisticaGast"  styleClass="stat-value stat-down"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Balance"           styleClass="stat-label"/>
            <Label fx:id="estadisticaBalan" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Movimientos"       styleClass="stat-label"/>
            <Label fx:id="estadisticaCount" styleClass="stat-value"/>
        </VBox>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="0">
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane" prefHeight="500">
            <VBox fx:id="txList" spacing="0"/>
        </ScrollPane>
    </VBox>
</VBox>
