<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.finanzapp.controller.HistorialController"
      styleClass="page" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Historial de movimientos" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="cmbMes"  prefWidth="130" styleClass="form-input"/>
        <ComboBox fx:id="cmbAnio" prefWidth="90"  styleClass="form-input"/>
        <ComboBox fx:id="cmbTipo" prefWidth="110" styleClass="form-input"/>
        <TextField fx:id="txtBuscar" promptText="🔍 Buscar..." styleClass="form-input" prefWidth="150"/>
    </HBox>

    <!-- Resumen mes -->
    <HBox spacing="12">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Ingresos"    styleClass="stat-label"/>
            <Label fx:id="statIng"   styleClass="stat-value stat-up"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Gastos"      styleClass="stat-label"/>
            <Label fx:id="statGast"  styleClass="stat-value stat-down"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Balance"     styleClass="stat-label"/>
            <Label fx:id="statBal"   styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Movimientos" styleClass="stat-label"/>
            <Label fx:id="statCount" styleClass="stat-value"/>
        </VBox>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="0">
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane" prefHeight="500">
            <VBox fx:id="txList" spacing="0"/>
        </ScrollPane>
    </VBox>
</VBox>
